#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

scan_staged_for_secrets() {
	echo "[pre-commit] secret scan"

	# Prefer gitleaks if available.
	if command -v gitleaks >/dev/null 2>&1; then
		if ! gitleaks protect --staged --redact --verbose; then
			echo "[pre-commit] gitleaks detected potential secrets." >&2
			return 1
		fi
		return 0
	fi

	# Fallback scan on added lines in staged diff.
	# This is intentionally conservative to avoid obvious leaks.
	local added
	added="$(git diff --cached --unified=0 --no-color -- . ':(exclude).githooks/pre-commit' | grep '^+' | grep -v '^+++' || true)"

	[[ -z "$added" ]] && return 0

	local pattern
	pattern='(ghp_[A-Za-z0-9]{20,}|AKIA[0-9A-Z]{16}|BEGIN (RSA |OPENSSH |EC )?PRIVATE KEY|AWS_SECRET_ACCESS_KEY|api[_-]?key[[:space:]]*[:=][[:space:]]*[^[:space:]]{12,}|token[[:space:]]*[:=][[:space:]]*[^[:space:]]{12,}|secret[[:space:]]*[:=][[:space:]]*[^[:space:]]{12,}|password[[:space:]]*[:=][[:space:]]*[^[:space:]]{8,})'

	if echo "$added" | grep -Eiq "$pattern"; then
		echo "[pre-commit] potential secret found in staged changes:" >&2
		echo "$added" | grep -Ein "$pattern" >&2 || true
		echo "[pre-commit] commit blocked. Remove or rotate secrets before committing." >&2
		return 1
	fi

	return 0
}

scan_staged_for_secrets

echo "[pre-commit] bash syntax check"
bash -n src/workday-notify.sh

echo "[pre-commit] running tests"
bash tests/test_schedule.sh

echo "[pre-commit] OK"
